{
  "expo": {
    "name": "birik-mobile",
    "slug": "birik-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/birik-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/birik-icon-fg.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F4ED",
      "dark": {
        "image": "./assets/birik-icon-fg.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D0D0D"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.birik.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Birik needs access to your photo library so you can import bank statement images.",
        "NSCameraUsageDescription": "Birik needs access to your camera so you can scan bank statements with your phone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/birik-icon-fg.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.birik.mobile"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22c55e"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Birik needs access to your photos so you can import bank statement images.",
          "cameraPermission": "Birik needs access to your camera so you can scan bank statements."
        }
      ],
      "expo-document-picker",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "014c0089-0938-4bf7-85ee-bbbb762bde53"
      }
    }
  }
}
