{
  "expo": {
    "name": "birik-mobile",
    "slug": "birik-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/birik-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/birik-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F4ED",
      "dark": {
        "image": "./assets/birik-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D0D0D"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/birik-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.birik.mobile"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/birik-icon.png",
          "color": "#22c55e"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "014c0089-0938-4bf7-85ee-bbbb762bde53"
      }
    }
  }
}
